# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# =============================================================================
# Virtual environments
# =============================================================================
.venv/
.venv_*/
venv/
env/

# =============================================================================
# Build & packaging
# =============================================================================
dist/
build/
*.egg-info/
*.egg
.eggs/

# =============================================================================
# Testing & coverage
# =============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/

# =============================================================================
# Type checking
# =============================================================================
.mypy_cache/
.ruff_cache/

# =============================================================================
# IDE / editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# parsling — project-specific
# =============================================================================

# Input PDFs — tracked as a folder but contents are ignored (large binary files)
input/*
!input/.gitkeep

# Parsed output — JSON, Markdown, CSV, images generated from PDFs
output/

# Downloaded ML model weights (EasyOCR, Docling models)
# These live in ~/.EasyOCR/ and ~/.cache/huggingface/ by default
# but exclude any locally cached copies
*.pt
*.pth
*.onnx
*.safetensors

# =============================================================================
# Secrets
# =============================================================================
.env

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
